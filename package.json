{
  "name": "promptsensei-mcp",
  "version": "1.1.1",
  "description": "An MCP server to analyze AI chat sessions and calculate token wastage using git repository analysis.",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "start:mcp": "node dist/mcp-server.js",
    "deploy": "pwsh -File ./deploy.ps1"
  },
  "bin": {
    "promptsensei": "dist/cli.js",
    "promptsensei-mcp": "dist/mcp-server.js"
  },
  "keywords": [
    "mcp",
    "ai",
    "token-wastage",
    "prompt-engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keyurbhogayata/promptSensei.git"
  },
  "author": "Keyur Bhogayata",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "gpt-tokenizer": "^3.4.0",
    "simple-git": "^3.36.0"
  }
}
